# 4h. Custom Circuit (user provides raw netlist lines)
# ------------------------------------------------------------------
def build_custom() -> tuple[str, str, str]:
    """
    Let the user type in arbitrary netlist statements.
    One line at a time; blank line finishes entry.
    """
    print("\n  ── Custom Circuit ──")
    print("  Enter netlist lines one at a time.")
    print("  Press Enter on a blank line when done.\n")
    print("  Example lines:")
    print("    V1 Vin 0 DC 5")
    print("    R1 Vin Vout 1k")
    print("    C1 Vout 0 1u")
    print("    .tran 1us 10ms\n")

    user_lines = []
    while True:
        line = input("  > ")
        if line.strip() == "":
            break
        user_lines.append(line)

    # Give it a title
    title = input("\n  Circuit title (used as filename): ").strip() or "custom_circuit"
    safe_name = re.sub(r"[^\w\-]", "_", title).lower()

    lines = [
        netlist_header(title),
    ] + user_lines + [
        netlist_footer(),
    ]
    return safe_name, "\n".join(lines), ""  # no ASC for custom circuits


# ---------------------------------------------------------------------------
# 4i. ASC SCHEMATIC TEMPLATE GENERATORS
#
# Coordinate system (derived from real LTspice .asc files, 16-unit grid):
#   voltage / current R180 at (sx, sy):
#       circuit pin → (sx,  sy-80),  GND pin → (sx,  sy+64)
#   res / cap / ind  R90  at (sx, sy)  [horizontal]:
#       left pin    → (sx-64, sy+16),  right pin → (sx+160, sy+16)
#   res / cap / ind  R0   at (sx, sy)  [vertical / shunt]:
#       top pin     → (sx+16, sy-48),  bottom pin → (sx+16, sy+96)
#       body top    → sy,              body bottom → sy+64
# ---------------------------------------------------------------------------

def _v1_sine(va: str, freq: str) -> str:
    """Voltage source block – SINE stimulus (R180 orientation, x=16)."""
    return (
        "SYMBOL voltage 16 208 R180\n"
        "WINDOW 0 24 96 Left 2\n"
        "WINDOW 3 24 16 Left 2\n"
        "SYMATTR InstName V1\n"
        f"SYMATTR Value SINE(0 {va} {freq})\n"
    )


def _v1_dc(vd: str) -> str:
    """Voltage source block – DC stimulus (R180 orientation, x=16)."""
    return (
        "SYMBOL voltage 16 208 R180\n"
        "WINDOW 0 24 96 Left 2\n"
        "WINDOW 3 24 16 Left 2\n"
        "SYMATTR InstName V1\n"
        f"SYMATTR Value DC {vd}\n"
    )


def _v1_ac(va: str) -> str:
    """Voltage source block – AC+SIN stimulus (R180 orientation, x=16)."""
    return (
        "SYMBOL voltage 16 208 R180\n"
        "WINDOW 0 24 96 Left 2\n"
        "WINDOW 3 24 16 Left 2\n"
        "SYMATTR InstName V1\n"
        f"SYMATTR Value AC {va} SIN(0 {va} 1k)\n"
    )


# Standard left-column V1 wires (x=16, circuit bus at y=128, GND at y=272)
_V1_WIRES = (
    "WIRE 16 256 16 128\n"   # wire occupying V1 body space
    "WIRE 16 272 16 256\n"   # V1 GND lead
    "FLAG 16 272 0\n"         # global GND
    "FLAG 16 128 Vin\n"       # Vin net label on left bus
)


def make_asc_rc_lowpass(r: str, c: str, va: str, freq: str, tran_cmd: str) -> str:
    """
    RC Low-Pass Filter schematic.
    V1(R180,x=16) → R1(R90, bus y=128) → C1(R0, shunt to GND)
    """
    return (
        "Version 4\nSHEET 1 880 680\n"
        # wires: horizontal bus + shunt cap leads
        "WIRE 96 128 16 128\n"
        "WIRE 240 128 96 128\n"
        "WIRE 240 176 240 128\n"   # cap top lead
        "WIRE 240 272 240 240\n"   # cap bottom lead
        + _V1_WIRES
        + "FLAG 240 272 0\n"
        "FLAG 240 128 Vout\n"
        + _v1_sine(va, freq)
        + "SYMBOL res 80 112 R90\n"
        "WINDOW 0 0 56 VBottom 2\n"
        "WINDOW 3 32 56 VTop 2\n"
        "SYMATTR InstName R1\n"
        f"SYMATTR Value {r}\n"
        "SYMBOL cap 224 176 R0\n"
        "SYMATTR InstName C1\n"
        f"SYMATTR Value {c}\n"
        f"TEXT -4 304 Left 2 !{tran_cmd}\n"
        "TEXT -4 328 Left 2 !.backanno\n"
    )


def make_asc_rc_highpass(r: str, c: str, va: str, freq: str, tran_cmd: str) -> str:
    """
    RC High-Pass Filter schematic.
    V1 → C1(R90, series) → R1(R0, shunt to GND)
    """
    return (
        "Version 4\nSHEET 1 880 680\n"
        "WIRE 96 128 16 128\n"
        "WIRE 240 128 96 128\n"
        "WIRE 240 176 240 128\n"   # res top lead
        "WIRE 240 272 240 240\n"   # res bottom lead
        + _V1_WIRES
        + "FLAG 240 272 0\n"
        "FLAG 240 128 Vout\n"
        + _v1_sine(va, freq)
        + "SYMBOL cap 80 112 R90\n"
        "WINDOW 0 0 56 VBottom 2\n"
        "WINDOW 3 32 56 VTop 2\n"
        "SYMATTR InstName C1\n"
        f"SYMATTR Value {c}\n"
        "SYMBOL res 224 176 R0\n"
        "WINDOW 0 38 -25 Left 2\n"
        "WINDOW 3 38 50 Left 2\n"
        "SYMATTR InstName R1\n"
        f"SYMATTR Value {r}\n"
        f"TEXT -4 304 Left 2 !{tran_cmd}\n"
        "TEXT -4 328 Left 2 !.backanno\n"
    )


def make_asc_rlc_bandpass(r: str, l: str, c: str, va: str, ac_cmd: str) -> str:
    """
    RLC Band-Pass Filter schematic.
    V1 → R1(R90) → L1(R90) → Vout, C1(R0) shunt to GND.
    Sheet extended to 560 px wide.
    R1 R90 at (80,112):  pins (16,128)↔(240,128)
    L1 R90 at (304,112): pins (240,128)↔(464,128)
    C1 R0  at (448,176): pins (464,128)↔(464,272)
    """
    return (
        "Version 4\nSHEET 1 560 680\n"
        "WIRE 240 128 16 128\n"
        "WIRE 464 128 240 128\n"
        "WIRE 464 176 464 128\n"   # C1 top lead
        "WIRE 464 272 464 240\n"   # C1 bottom lead
        + _V1_WIRES
        + "FLAG 464 272 0\n"
        "FLAG 240 128 N1\n"
        "FLAG 464 128 Vout\n"
        + _v1_ac(va)
        + "SYMBOL res 80 112 R90\n"
        "WINDOW 0 0 56 VBottom 2\n"
        "WINDOW 3 32 56 VTop 2\n"
        "SYMATTR InstName R1\n"
        f"SYMATTR Value {r}\n"
        "SYMBOL ind 304 112 R90\n"
        "WINDOW 0 -14 -40 Left 2\n"
        "WINDOW 3 -19 16 Left 2\n"
        "SYMATTR InstName L1\n"
        f"SYMATTR Value {l}\n"
        "SYMBOL cap 448 176 R0\n"
        "SYMATTR InstName C1\n"
        f"SYMATTR Value {c}\n"
        f"TEXT -4 304 Left 2 !{ac_cmd}\n"
        "TEXT -4 328 Left 2 !.backanno\n"
    )


def make_asc_rlc_bandstop(r: str, l: str, c: str, rl: str, va: str, ac_cmd: str) -> str:
    """
    RLC Band-Stop schematic.
    V1 → R1(series) → N1, L1‖C1 (parallel tank) → Vout, Rl(shunt) → GND.
    R1 R90  at (80,112):  (16,128)↔(240,128)
    L1 R0   at (224,176): (240,128)↔(240,272)   vertical
    C1 R0   at (352,176): (368,128)↔(368,272)   vertical, parallel with L1
    Rl R0   at (352,320): (368,272)↔(368,416)   Rload to GND
    """
    return (
        "Version 4\nSHEET 1 560 480\n"
        # series bus and N1→C1 branch
        "WIRE 240 128 16 128\n"   # Vin → R1 → N1
        "WIRE 368 128 240 128\n"  # N1 → C1 top
        # L1 vertical wires
        "WIRE 240 176 240 128\n"  # L1 top lead
        "WIRE 240 272 240 240\n"  # L1 bottom lead
        # C1 vertical wires
        "WIRE 368 176 368 128\n"  # C1 top lead
        "WIRE 368 272 368 240\n"  # C1 bottom lead
        # Vout bus (L1 bottom ↔ C1 bottom)
        "WIRE 368 272 240 272\n"
        # Rload leads
        "WIRE 368 320 368 272\n"  # Rload top lead
        "WIRE 368 416 368 384\n" # Rload bottom lead
        + _V1_WIRES
        + "FLAG 368 416 0\n"
