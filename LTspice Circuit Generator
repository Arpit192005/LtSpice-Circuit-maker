# Per-user installs (LTspice 24+) live under %LOCALAPPDATA%
_LOCAL = os.environ.get("LOCALAPPDATA", "")
_LTSPICE_PATHS = [
    # LTspice 24 – per-user install (most common on Win 10/11)
    os.path.join(_LOCAL, "Programs", "ADI", "LTspice", "LTspice.exe"),
    os.path.join(_LOCAL, "ADI", "LTspice", "LTspice.exe"),
    # System-wide installs
    r"C:\Program Files\ADI\LTspice\LTspice.exe",
    r"C:\Program Files (x86)\ADI\LTspice\LTspice.exe",
    r"C:\Program Files\LTC\LTspiceXVII\XVIIx64.exe",
    r"C:\Program Files\LTC\LTspiceXVII\XVIIx86.exe",
    r"C:\Program Files (x86)\LTC\LTspiceXVII\XVIIx64.exe",
]


def find_ltspice() -> Optional[str]:
    """Return the path to the LTspice executable, or None if not found."""
    for path in _LTSPICE_PATHS:
        if path and os.path.isfile(path):
            return path
    return None


def _launch(exe_or_lnk: str, circuit_file: Path) -> None:
    """
    Launch LTspice with the given circuit file.
    - If exe_or_lnk ends with .lnk (a Windows shortcut) or is not an .exe,
      use os.startfile() / ShellExecute so Windows resolves it properly.
    - Otherwise use subprocess.Popen for direct execution.
    """
    ext = os.path.splitext(exe_or_lnk)[1].lower()
    if ext in (".lnk", "") or not os.path.isfile(exe_or_lnk):
        # ShellExecute can open .lnk files and handles UAC automatically
        import ctypes
        ctypes.windll.shell32.ShellExecuteW(
            None, "open", exe_or_lnk, str(circuit_file), None, 1
        )
    else:
        subprocess.Popen([exe_or_lnk, str(circuit_file)])


def open_in_ltspice(circuit_file: Path) -> None:
    """Attempt to open the .cir file in LTspice."""
    ltspice = find_ltspice()
    if ltspice is None:
        print("  [!] LTspice not found in standard locations.")
        print("  Tip: provide the path to LTspice.exe (not the .lnk shortcut).")
        custom = input("  Enter path to LTspice.exe (or press Enter to skip): ").strip().strip('"')
        if not custom:
            return
        ltspice = custom

    try:
        _launch(ltspice, circuit_file)
        print(f"  [OK] Opened '{circuit_file.name}' in LTspice.")
    except Exception as exc:
        print(f"  [ERR] Failed to open LTspice: {exc}")


