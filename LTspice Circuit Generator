# ------------------------------------------------------------------
# 4j. Half-Wave Rectifier  ← EXAMPLE NEW CIRCUIT
# ------------------------------------------------------------------
def build_half_wave_rectifier() -> tuple[str, str, str]:
    """
    Half-Wave Rectifier topology:

        Vin ──[D1]──┬── Vout
                    │
                   [RL]   (load resistor)
                    │
                   GND

    A diode passes only the positive half-cycle of the AC input.
    """
    print("\n  ── Half-Wave Rectifier ──")
    va   = prompt_value("Source amplitude (V)",       default="5")
    freq = prompt_value("Source frequency (Hz)",       default="50")
    rl   = prompt_value("Load resistance RL",          default="1k")

    # Diode model choice
    diode = prompt_choice(
        "Diode model:",
        ["1N4148 (signal)", "1N4007 (power)", "Ideal (no drops)"],
        default=1,
    )
    diode_model_name = {"1N4148 (signal)": "1N4148",
                        "1N4007 (power)":  "1N4007",
                        "Ideal (no drops)": "DIDEAL"}[diode]

    # Model lines (LTspice built-in for 1N4148 / 1N4007; custom for ideal)
    model_lines = {
        "1N4148":  ".model 1N4148 D(Is=2.52n Rs=0.568 N=1.752 Cjo=4p M=0.4 tt=20n)",
        "1N4007":  ".model 1N4007 D(Is=76.9p Rs=0.642 N=1.45  Cjo=26.5p M=0.333 tt=4.32u)",
        "DIDEAL":  ".model DIDEAL D(Ron=0.01 Roff=1G Vfwd=0)",
    }[diode_model_name]

    # Sensible transient stop: 10 periods
    try:
        num_freq = float(re.match(r"[0-9.eE+\-]+", freq).group())
        if freq.endswith("k") or freq.endswith("K"):
            num_freq *= 1e3
        stop = 10 / num_freq
    except Exception:
        stop = 200e-3

    tran_cmd = build_tran_cmd(stop)

    # ── Step 1a: Build .cir netlist ──────────────────────────────
    lines = [
        netlist_header("Half-Wave Rectifier"),
        f"V1 Vin 0 SINE(0 {va} {freq})",
        f"D1 Vin Vout {diode_model_name}",
        f"RL Vout 0 {rl}",
        f"",
        model_lines,
        tran_cmd,
        netlist_footer(),
    ]

    # ── Step 1b: Build .asc schematic ────────────────────────────
    asc = make_asc_half_wave_rectifier(va, freq, rl, diode_model_name, tran_cmd)

    return "half_wave_rectifier", "\n".join(lines), asc


def make_asc_half_wave_rectifier(va: str, freq: str, rl: str,
                                  diode_model: str, tran_cmd: str) -> str:
    """
    Half-Wave Rectifier schematic.
    V1(R180, x=16) → D1 (horizontal, anode=Vin bus, cathode=Vout) → RL (shunt).

    Layout:
      V1  R180 at (16, 208)   : Vin pin (16,128), GND pin (16,272)
      D1  R90  at (80, 112)   : anode=(16,128), cathode=(208,128)
      RL  R0   at (192, 176)  : top=(208,128),  bottom=(208,272)
    """
    return (
        "Version 4\nSHEET 1 560 460\n"
        # Horizontal bus Vin → D1 → RL
        "WIRE 96 128 16 128\n"    # Vin → D1 anode
        "WIRE 208 128 96 128\n"   # D1 cathode → RL top
        # RL shunt leads
        "WIRE 208 176 208 128\n"  # RL top lead
        "WIRE 208 272 208 240\n"  # RL bottom lead
        + _V1_WIRES
        + "FLAG 208 272 0\n"       # GND at RL bottom
        "FLAG 208 128 Vout\n"      # Vout net label
        + _v1_sine(va, freq)
        # D1: diode R90 → anode on left, cathode on right
        + "SYMBOL diode 96 112 R90\n"
        "WINDOW 0 0 32 VBottom 2\n"
        "WINDOW 3 32 32 VTop 2\n"
        "SYMATTR InstName D1\n"
        f"SYMATTR Value {diode_model}\n"
        # RL: shunt resistor R0
        "SYMBOL res 192 176 R0\n"
        "WINDOW 0 38 -25 Left 2\n"
        "WINDOW 3 38 50 Left 2\n"
        "SYMATTR InstName RL\n"
        f"SYMATTR Value {rl}\n"
        f"TEXT -4 304 Left 2 !{tran_cmd}\n"
        "TEXT -4 328 Left 2 !.backanno\n"
    )


# ---------------------------------------------------------------------------
# 5. FAULT INJECTION
#    Allow the user to deliberately corrupt a component value to simulate
#    a faulty circuit (useful for ML dataset generation).
# ---------------------------------------------------------------------------

def _apply_fault_to_asc(asc: str, comp: str, new_val: str) -> str:
    """Replace a component's SYMATTR Value in an .asc schematic string."""
    if not asc:
        return asc
    pattern = re.compile(
        rf"(SYMATTR InstName {re.escape(comp)}\n)(SYMATTR Value )(\S+)",
        re.MULTILINE,
    )
    new_asc, _ = pattern.subn(lambda m: m.group(1) + m.group(2) + new_val, asc)
    return new_asc


def inject_fault(netlist: str, asc: str = "") -> tuple[str, str]:
    """
    Interactively inject a fault into both the netlist (.cir) and schematic
    (.asc) by replacing one component value with a broken value.

    Returns (modified_netlist, modified_asc).
    """
    print("\n  ── Fault Injection (for ML dataset) ──")
    fault_types = [
        "No fault (healthy circuit)",
        "Open circuit  (replace one component with 1G value)",
        "Short circuit (replace one component with 1n value)",
        "Changed value (enter component name + new value)",
    ]
    choice = prompt_choice("Select fault type:", fault_types, default=1)

    if choice == fault_types[0]:
        return netlist, asc   # unchanged

    comp = input("  Component reference to modify (e.g. R1, C1, L1): ").strip()
    if not comp:
        print("  [!] No component given - skipping fault injection.")
        return netlist, asc

    if choice == fault_types[1]:
        new_val = "1G"   # open circuit approximation
    elif choice == fault_types[2]:
        new_val = "1n"   # short circuit approximation
    else:
        new_val = prompt_value(f"New value for {comp}", default="100k")

    # ── Patch netlist (.cir) ──────────────────────────────────────
    pattern = re.compile(
        rf"^({re.escape(comp)}\s+\S+\s+\S+\s+)(\S+)",
        re.IGNORECASE | re.MULTILINE,
    )
    new_netlist, count = pattern.subn(lambda m: m.group(1) + new_val, netlist)
    if count == 0:
        print(f"  [!] Component '{comp}' not found in netlist - no fault injected.")
        return netlist, asc

    new_netlist = new_netlist.replace(
        "* Generated by LTspice Circuit Generator",
        f"* Generated by LTspice Circuit Generator\n* FAULT: {comp} changed to {new_val}",
    )

    # ── Patch schematic (.asc) ────────────────────────────────────
    new_asc = _apply_fault_to_asc(asc, comp, new_val)

    print(f"  [OK] Fault injected: {comp} -> {new_val}")
    return new_netlist, new_asc


