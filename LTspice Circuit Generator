def banner() -> None:
    print("=" * 60)
    print("   LTspice Circuit Netlist Generator")
    print("   For simulation & ML fault-dataset creation")
    print("=" * 60)


def main() -> None:
    banner()

    # ── Step 1: Choose circuit type ──────────────────────────────
    circuit_names = list(CIRCUIT_BUILDERS.keys())
    chosen = prompt_choice("Select circuit type:", circuit_names, default=1)
    builder = CIRCUIT_BUILDERS[chosen]

    # ── Step 2: Collect parameters and build netlist ─────────────
    print(f"\n{'─'*60}")
    print(f"  Configuring: {chosen}")
    print(f"{'─'*60}")
    file_name, netlist, asc = builder()

    # ── Step 3: Optional fault injection ─────────────────────────
    print(f"\n{'─'*60}")
    inject = input("  Inject a fault? (y/N): ").strip().lower()
    if inject in ("y", "yes"):
        netlist, asc = inject_fault(netlist, asc)
        file_name += "_fault"

    # ── Step 4: Preview ──────────────────────────────────────────
    print(f"\n{'─'*60}")
    print("  Netlist preview:")
    print(f"{'─'*60}")
    for line in netlist.splitlines():
        print(f"    {line}")

    # ── Step 5: Save ─────────────────────────────────────────────
    print(f"\n{'─'*60}")
    while True:
        out_dir_raw = input(
            f"  Output directory [default: {Path.cwd()}]: "
        ).strip().strip('"')
        out_dir = Path(out_dir_raw) if out_dir_raw else Path.cwd()
        try:
            out_dir = _safe_output_dir(Path(out_dir_raw) if out_dir_raw else None)
        except ValueError as e:
            print(f"  [!] {e}")
            print("  [!] Please enter a folder path, not a file path. Try again.")
            continue

        saved_cir = save_netlist(file_name, netlist, out_dir)
        print(f"  [OK] .cir saved: {saved_cir}")

        saved_asc: Optional[Path] = None
        if asc:
            # Also save same-named .asc alongside the .cir
            asc_path = out_dir / f"{saved_cir.stem}.asc"
            counter = 1
            while asc_path.exists():
                asc_path = out_dir / f"{saved_cir.stem}_{counter}.asc"
                counter += 1
            asc_path.write_text(asc, encoding="utf-8")
            saved_asc = asc_path
            print(f"  [OK] .asc saved: {saved_asc}")
        break

    # ── Step 6: Open in LTspice ───────────────────────────────────
    print(f"\n{'─'*60}")
    open_lt = input("  Open in LTspice now? (y/N): ").strip().lower()
    if open_lt in ("y", "yes"):
        # Prefer .asc (schematic view) over .cir (text netlist)
        open_in_ltspice(saved_asc if saved_asc else saved_cir)

    # ── Step 7: Generate another? ────────────────────────────────
    print(f"\n{'─'*60}")
    again = input("  Generate another circuit? (y/N): ").strip().lower()
    if again in ("y", "yes"):
        print()
        main()
    else:
        print("\n  Done! Happy simulating!\n")


