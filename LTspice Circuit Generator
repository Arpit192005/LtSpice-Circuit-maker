def _safe_output_dir(output_dir: Optional[Path]) -> Path:
    """Resolve output directory, raising ValueError if path is an existing file."""
    if output_dir is None:
        output_dir = Path.cwd()
    if output_dir.exists() and not output_dir.is_dir():
        raise ValueError(f"Path is a file, not a directory: {output_dir}")
    output_dir.mkdir(parents=True, exist_ok=True)
    return output_dir


def save_netlist(name: str, netlist: str, output_dir: Path = None) -> Path:
    """Save the netlist string to a .cir file and return the Path."""
    output_dir = _safe_output_dir(output_dir)

    filepath = output_dir / f"{name}.cir"
    # If file already exists, add a numeric suffix to avoid overwriting
    counter = 1
    while filepath.exists():
        filepath = output_dir / f"{name}_{counter}.cir"
        counter += 1

    filepath.write_text(netlist, encoding="utf-8")
    return filepath


