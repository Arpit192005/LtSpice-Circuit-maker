# ---------------------------------------------------------------------------
# 1. VALUE PARSER
#    Converts human-readable component values (e.g. "1k", "10mH", "1uF")
#    to LTspice-compatible strings.
# ---------------------------------------------------------------------------

# Suffix → LTspice suffix mapping
_SUFFIX_MAP = {
    "t":  "T",   # Tera
    "g":  "G",   # Giga
    "meg": "MEG", # Mega (LTspice uses MEG not M for 1e6)
    "k":  "k",   # kilo
    "m":  "m",   # milli   (lowercase in LTspice)
    "u":  "u",   # micro
    "n":  "n",   # nano
    "p":  "p",   # pico
    "f":  "f",   # femto
    # Unit aliases (H, F, etc.) are stripped; LTspice infers them from component letter
    "h":  "",    # Henry   – unit, not a multiplier
    "f_": "",    # Farad   – unit (avoid collision with "f" = femto)
}

# Regex: number optionally followed by a suffix/unit
_VALUE_RE = re.compile(
    r"^\s*([+-]?[0-9]*\.?[0-9]+(?:[eE][+-]?[0-9]+)?)"
    r"\s*(T|G|MEG|Meg|meg|K|k|M|m|u|µ|U|n|N|p|P|f|F|mH|uH|nH|mF|uF|nF|pF|H|h)?\s*$",
    re.IGNORECASE,
)


def parse_value(raw: str) -> str:
    """
    Parse a user-supplied component value like '1k', '10mH', '1uF', '5V'
    and return an LTspice-compatible string (e.g. '1k', '10m', '1u').

    Raises ValueError for unparseable inputs.
    """
    raw = raw.strip()
    m = _VALUE_RE.match(raw)
    if not m:
        raise ValueError(f"Cannot parse value: '{raw}'")

    num, suffix = m.group(1), (m.group(2) or "").lower()

    # Strip unit letters that only indicate the physical quantity (H, F, V, A, Ω)
    # but keep multiplier suffixes
    unit_only = {"h", "f", "v", "a", "ω", "ohm"}  # pure units
    multiplier_map = {
        "t": "T", "g": "G", "meg": "MEG", "k": "k",
        "m": "m", "mh": "m", "mf": "m",   # milli-Henry / milli-Farad
        "u": "u", "µ": "u", "uh": "u", "uf": "u",
        "n": "n", "nh": "n", "nf": "n",
        "p": "p", "pf": "p",
    }

    ltspice_suffix = multiplier_map.get(suffix, "")
    return f"{num}{ltspice_suffix}"


def prompt_value(prompt_text: str, default: str = None) -> str:
    """Prompt the user for a component value; returns LTspice-ready string."""
    hint = f" [default: {default}]" if default else ""
    while True:
        raw = input(f"  {prompt_text}{hint}: ").strip()
        if raw == "" and default is not None:
            raw = default
        try:
            return parse_value(raw)
        except ValueError as exc:
            print(f"    [!] {exc}  - try again (e.g. 1k, 10m, 470n)")


def prompt_int(prompt_text: str, default: int = None, lo: int = None, hi: int = None) -> int:
    """Prompt the user for an integer, with optional bounds."""
    hint = f" [default: {default}]" if default is not None else ""
    while True:
        raw = input(f"  {prompt_text}{hint}: ").strip()
        if raw == "" and default is not None:
            return default
        try:
            val = int(raw)
            if lo is not None and val < lo:
                raise ValueError(f"Must be ≥ {lo}")
            if hi is not None and val > hi:
                raise ValueError(f"Must be ≤ {hi}")
            return val
        except ValueError as exc:
            print(f"    [!] {exc}  - try again")


def prompt_choice(prompt_text: str, choices: list, default: int = 1) -> str:
    """Display a numbered menu and return the chosen string."""
    print(f"\n  {prompt_text}")
    for idx, choice in enumerate(choices, start=1):
        marker = " (default)" if idx == default else ""
        print(f"    [{idx}] {choice}{marker}")
    while True:
        raw = input("  Enter number: ").strip()
        if raw == "":
            return choices[default - 1]
        try:
            idx = int(raw)
            if 1 <= idx <= len(choices):
                return choices[idx - 1]
        except ValueError:
            pass
        print(f"    [!] Please enter a number between 1 and {len(choices)}")


# ---------------------------------------------------------------------------
# 2. SIMULATION COMMAND HELPERS
# ---------------------------------------------------------------------------

def build_tran_cmd(stop_time_s: float, step_time_s: float = None) -> str:
    """Build a .tran simulation command string."""
    if step_time_s is None:
        step_time_s = stop_time_s / 1000
    return f".tran {_fmt_time(step_time_s)} {_fmt_time(stop_time_s)}"


def build_ac_cmd(points_per_decade: int = 100,
                 f_start: str = "1", f_stop: str = "1Meg") -> str:
    """Build a .ac simulation command string."""
    return f".ac dec {points_per_decade} {f_start} {f_stop}"


def _fmt_time(seconds: float) -> str:
    """Format a time value in seconds to a compact LTspice string."""
    if seconds >= 1:
        return f"{seconds}s"
    elif seconds >= 1e-3:
        return f"{seconds * 1e3:.6g}ms"
    elif seconds >= 1e-6:
        return f"{seconds * 1e6:.6g}us"
    else:
        return f"{seconds * 1e9:.6g}ns"


# ---------------------------------------------------------------------------
# 3. NETLIST HEADER / FOOTER
# ---------------------------------------------------------------------------

def netlist_header(title: str) -> str:
    return f"* {title}\n* Generated by LTspice Circuit Generator\n"


def netlist_footer() -> str:
    return "\n.backanno\n.end\n"


