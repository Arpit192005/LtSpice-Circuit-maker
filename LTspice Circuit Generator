# 4a. RC Low-Pass Filter
# ------------------------------------------------------------------
def build_rc_lowpass() -> tuple[str, str, str]:
    """
    RC Low-Pass Filter topology:

        Vin ──[R]──┬── Vout
                   │
                  [C]
                   │
                  GND
    """
    print("\n  ── RC Low-Pass Filter ──")
    r  = prompt_value("Resistance R",  default="1k")
    c  = prompt_value("Capacitance C", default="1u")
    va = prompt_value("Source amplitude (V)", default="5")
    freq = prompt_value("Source frequency (Hz)", default="1k")

    # Determine a sensible transient stop time: 10 periods
    try:
        num_freq = float(re.match(r"[0-9.eE+\-]+", freq).group())
        if freq.endswith("k") or freq.endswith("K"):
            num_freq *= 1e3
        stop = 10 / num_freq
    except Exception:
        stop = 10e-3

    tran_cmd = build_tran_cmd(stop)
    lines = [
        netlist_header("RC Low-Pass Filter"),
        f"V1 Vin 0 SINE(0 {va} {freq})",
        f"R1 Vin Vout {r}",
        f"C1 Vout 0 {c}",
        f"",
        tran_cmd,
        netlist_footer(),
    ]
    asc = make_asc_rc_lowpass(r, c, va, freq, tran_cmd)
    return "rc_lowpass", "\n".join(lines), asc


